# Mặc định chạy mock mode để demo không cần API key.
LLM_PROVIDER=mock

# Khuyến nghị cho demo free:
# LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_OUTPUT_TOKENS=1800

# Chuyển sang openai khi muốn dùng LLM thật.
# LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=1800

# Truy xuất tài liệu: bm25 | vector | hybrid
RETRIEVAL_MODE=hybrid
HYBRID_BM25_WEIGHT=0.7
HYBRID_VECTOR_WEIGHT=0.3
VECTOR_DB_PATH=data/knowledge.sqlite
VECTOR_MIN_SCORE=0.05
VECTOR_TOP_K_MULTIPLIER=3
HYBRID_ALLOW_VECTOR_ONLY=false

# Embedding cho vector search.
# local_hash chạy offline, đủ cho demo kỹ thuật nhưng không thay thế embedding ngữ nghĩa thật.
EMBEDDING_PROVIDER=local_hash
EMBEDDING_DIMENSIONS=384

# Khi muốn tìm kiếm ngữ nghĩa thật bằng OpenAI embedding:
# EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Hoặc dùng model local nếu đã cài thêm sentence-transformers:
# EMBEDDING_PROVIDER=sentence_transformers
SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
